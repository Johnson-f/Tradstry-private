# Agent service network settings
AGENTS_SERVICE_HOST=0.0.0.0
AGENTS_SERVICE_PORT=8091
AGENTS_SERVICE_WEBSOCKET_PATH=/ws/v1/agents

# Prompt and storage paths
# AGENTS_PROMPT_ROOT=src/tradstry_agents/prompts
# OPENVIKING_DATA_ROOT=data/openviking

# Groq chat provider
GROQ_API_KEY=
GROQ_MODEL=llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# OpenRouter embedding provider
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/embeddings

# Runtime timeouts
AGENTS_RESPONSE_TIMEOUT_SECONDS=60
AGENTS_TOOL_TIMEOUT_SECONDS=20
AGENTS_HEARTBEAT_INTERVAL_SECONDS=15
