# Production Environment Variables for Backend
# Create a file named .env.production at the root of the backend
# copy this file to backend/.env.production and replace <your-*> placeholders with actual values
# The .env.production file is only used for production deploying on a VPS or anywhere via docker, for development create a .env file

# Turso Configuration
REGISTRY_DB_URL=
REGISTRY_DB_TOKEN=

# Turso API Configuration (for creating new databases)
TURSO_API_TOKEN=
TURSO_ORG=

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google calendar
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# replace to https://your-domain.com/api/auth/callback/google in production
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Cron job
CRON_SECRET=5

# Caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI - vector embedding
VOYAGER_API_KEY=
VOYAGER_API_URL=https://api.voyageai.com/v1
VOYAGER_MODEL=voyage-finance-2

# Upstash Vector (1024 dimensions for voyage-finance-2)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Open router
OPENROUTER_API_KEY=
OPENROUTER_SITE_NAME=
GEMINI_API_KEY=

# Model Selector Settings
MODEL_FALLBACK_ENABLED=
MAX_FALLBACK_ATTEMPTS=

# Search
UPSTASH_SEARCH_REST_URL=
UPSTASH_SEARCH_REST_TOKEN=
HYBRID_SEARCH_ENABLED=
AI_RERANKING_ENABLED=
HYBRID_VECTOR_WEIGHT=
HYBRID_KEYWORD_WEIGHT=

# Self-host Qdrant (port 6334 for gRPC)
# Search the web on how to self host QDRANT on a VPS, use the qdrant.sh script
QDRANT_URL=
QDRANT_API_KEY=

# Web push notis
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:support@your-journal

# Brokerage
SNAPTRADE_SERVICE_URL=http://localhost:8080
ENABLE_BROKERAGE_SYNC_CRON=true # For automation sync

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Schema config -> set this to true in production
ENABLE_STARTUP_SCHEMA_SYNC=false

FINANCEQUERY_BASE_URL="https://finance-query-onrender.com"

# Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Localhost for developement
# https for production
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/auth/google/callback

# Email Service
RESEND_API_KEY=
RESEND_FROM_EMAIL=Your-journal <Your-name@your-journal.com>

# Server Configuration
PORT=9000
RUST_LOG=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
